   "source": [
    "<style>\n",
    "/* Center the page */\n",
    "body {\n",
    "    display: flex;\n",
    "    justify-content: center;\n",
    "    align-items: center;\n",
    "    min-height: 100vh;\n",
    "    background-color: #f4f4f9;\n",
    "    font-family: 'Arial', sans-serif;\n",
    "    margin: 0;\n",
    "}\n",
    "\n",
    "/* Main container */\n",
    "#titanic-app {\n",
    "    border: 1px solid #ccc;\n",
    "    padding: 20px;\n",
    "    border-radius: 10px;\n",
    "    max-width: 400px;\n",
    "    width: 100%;\n",
    "    background-color: #ffffff;\n",
    "    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n",
    "}\n",
    "\n",
    "/* Inputs */\n",
    "#titanic-app input,\n",
    "#titanic-app select {\n",
    "    width: 100%;\n",
    "    padding: 10px;\n",
    "    margin-top: 5px;\n",
    "    margin-bottom: 15px;\n",
    "    border: 1px solid #ccc;\n",
    "    border-radius: 5px;\n",
    "    font-size: 14px;\n",
    "}\n",
    "\n",
    "/* White text for selected dropdown value */\n",
    "#titanic-app select {\n",
    "    color: white;\n",
    "    background-color: #007bff;\n",
    "}\n",
    "\n",
    "/* Dropdown list options */\n",
    "#titanic-app option {\n",
    "    color: black;\n",
    "}\n",
    "\n",
    "/* Labels */\n",
    "#titanic-app label {\n",
    "    font-weight: bold;\n",
    "    font-size: 14px;\n",
    "    color: #333;\n",
    "}\n",
    "\n",
    "/* Button */\n",
    "#titanic-app button {\n",
    "    width: 100%;\n",
    "    padding: 10px;\n",
    "    background-color: #007bff;\n",
    "    color: white;\n",
    "    border: none;\n",
    "    border-radius: 5px;\n",
    "    cursor: pointer;\n",
    "    font-size: 16px;\n",
    "    font-weight: bold;\n",
    "    transition: background-color 0.3s;\n",
    "}\n",
    "\n",
    "#titanic-app button:hover {\n",
    "    background-color: #0056b3;\n",
    "}\n",
    "\n",
    "/* Response text */\n",
    "#response {\n",
    "    margin-top: 20px;\n",
    "    font-weight: bold;\n",
    "    text-align: center;\n",
    "    font-size: 16px;\n",
    "}\n",
    "</style>\n",
    "\n",
    "<div id=\"titanic-app\">\n",
    "    <div style=\"margin-bottom: 10px;\">\n",
    "        <label>Passenger Class:</label><br>\n",
    "        <select id=\"pclass\">\n",
    "            <option value=\"1\">First Class</option>\n",
    "            <option value=\"2\">Second Class</option>\n",
    "            <option value=\"3\">Third Class</option>\n",
    "        </select>\n",
    "    </div>\n",
    "    <div style=\"margin-bottom: 10px;\">\n",
    "        <label>Sex:</label><br>\n",
    "        <select id=\"sex\">\n",
    "            <option value=\"male\">Male</option>\n",
    "            <option value=\"female\">Female</option>\n",
    "        </select>\n",
    "    </div>\n",
    "    <div style=\"margin-bottom: 10px;\">\n",
    "        <label>Age:</label>\n",
    "        <input type=\"number\" id=\"age\" value=\"25\">\n",
    "    </div>\n",
    "    <div style=\"margin-bottom: 10px;\">\n",
    "        <label>Siblings/Spouses Aboard:</label>\n",
    "        <input type=\"number\" id=\"sibsp\" value=\"0\">\n",
    "    </div>\n",
    "    <div style=\"margin-bottom: 10px;\">\n",
    "        <label>Parents/Children Aboard:</label>\n",
    "        <input type=\"number\" id=\"parch\" value=\"0\">\n",
    "    </div>\n",
    "    <div style=\"margin-bottom: 10px;\">\n",
    "        <label>Fare Paid:</label>\n",
    "        <input type=\"number\" id=\"fare\" value=\"20\">\n",
    "    </div>\n",
    "    <div style=\"margin-bottom: 10px;\">\n",
    "        <label>Embarked From:</label><br>\n",
    "        <select id=\"embarked\">\n",
    "            <option value=\"S\">Southampton</option>\n",
    "            <option value=\"C\">Cherbourg</option>\n",
    "            <option value=\"Q\">Queenstown</option>\n",
    "        </select>\n",
    "    </div>\n",
    "    <div style=\"margin-bottom: 10px;\">\n",
    "        <input type=\"checkbox\" id=\"alone\"> <label>Traveling Alone</label>\n",
    "    </div>\n",
    "    <button onclick=\"predict()\">Predict Survival</button>\n",
    "    <div id=\"response\"></div>\n",
    "</div>\n",
    "\n",
    "<script>\n",
    "function predict() {\n",
    "    const url = \"http://localhost:8587/api/titanic/predict\";\n",
    "    const responseDiv = document.getElementById('response');\n",
    "\n",
    "    const data = {\n",
    "        pclass: parseInt(document.getElementById('pclass').value),\n",
    "        sex: document.getElementById('sex').value,\n",
    "        age: parseFloat(document.getElementById('age').value),\n",
    "        sibsp: parseInt(document.getElementById('sibsp').value),\n",
    "        parch: parseInt(document.getElementById('parch').value),\n",
    "        fare: parseFloat(document.getElementById('fare').value),\n",
    "        embarked: document.getElementById('embarked').value,\n",
    "        alone: document.getElementById('alone').checked,\n",
    "        name: \"User\"\n",
    "    };\n",
    "\n",
    "    fetch(url, {\n",
    "        method: 'POST',\n",
    "        headers: { 'Content-Type': 'application/json' },\n",
    "        body: JSON.stringify(data)\n",
    "    })\n",
    "    .then(response => response.json())\n",
    "    .then(result => {\n",
    "        const survive = (result.survive * 100).toFixed(2);\n",
    "        const die = (result.die * 100).toFixed(2);\n",
    "        responseDiv.innerHTML = `Survival: ${survive}% <br> Death: ${die}%`;\n",
    "        responseDiv.style.color = result.survive > 0.5 ? \"green\" : \"red\";\n",
    "    })\n",
    "    .catch(error => {\n",
    "        console.error('Error:', error);\n",
    "        responseDiv.innerHTML = \"Error contacting API. Ensure Flask is running.\";\n",
    "        responseDiv.style.color = \"red\";\n",
    "    });\n",
    "}\n",
    "</script>"
   ]
  }
 ],
